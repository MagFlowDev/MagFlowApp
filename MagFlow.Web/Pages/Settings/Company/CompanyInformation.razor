@using MagFlow.Shared.DTOs.Core
@using MudBlazor

<div class="d-flex flex-column align-items-start w-100" style="max-width: 590px; min-height: 0; gap: 40px; padding-right: 40px;">
    <MudText Typo="Typo.h5">@Localizer[Langs.GeneralInformation]</MudText>
    <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 16px">
        <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 4px; padding-bottom: 1px;">
            <MudTextField Label="@Localizer[Langs.CompanyName]" T="string" Text="@_company?.Name" Class="w-100" Style="font-weight: 600" ReadOnly></MudTextField>
        </div>
        <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 4px; padding-bottom: 1px;">
            <MudTextField Label="@Localizer[Langs.TaxNumber]" T="string" Text="@_company?.TaxNumber" Class="w-100" Style="font-weight: 600" ReadOnly></MudTextField>
        </div>
        <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 4px; padding-bottom: 1px;">
            <MudTextField Label="@Localizer[Langs.CreationDate]" T="string" Text="@_company?.CreatedAt.ToShortDateString()" Class="w-100" Style="font-weight: 600" ReadOnly></MudTextField>
        </div>
    </div>
    <div class="d-flex flex-column align-items-start w-100" style="gap: 4px">
        <MudText Typo="Typo.h6">@Localizer[Langs.CompanyAddress]</MudText>
        <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 16px">
            <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 4px; padding-bottom: 1px;">
                <MudTextField Label="Ulica" T="string" Text="@_company?.Address?.Line1" Class="w-100" Style="font-weight: 600" ReadOnly Variant="Variant.Outlined"></MudTextField>
                <MudTextField Label="Kod pocztowy" T="string" Text="@_company?.Address?.ZipCode" Class="w-100" Style="font-weight: 600" ReadOnly Variant="Variant.Outlined"></MudTextField>
                <MudTextField Label="Miasto" T="string" Text="@_company?.Address?.City" Class="w-100" Style="font-weight: 600" ReadOnly Variant="Variant.Outlined"></MudTextField>
                <MudTextField Label="Kraj" T="string" Text="@_company?.Address?.Country" Class="w-100" Style="font-weight: 600" ReadOnly Variant="Variant.Outlined"></MudTextField>
            </div>
        </div>
    </div>
    
</div>


@code {
    [CascadingParameter(Name = "Company")]
    CompanyDTO? _company { get; set; }
}
