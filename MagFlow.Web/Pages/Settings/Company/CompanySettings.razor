@page "/company/settings"
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CoreScope
@using MagFlow.Shared.Extensions.Enum
@using MagFlow.Shared.Models
@using MagFlow.Shared.Models.Enumerators
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

@layout MainLayout
@inject ICompanyService CompanyService
@inject IJSRuntime JS

@attribute [Authorize(Roles = $"{nameof(AppRole.CompanyAdmin)},{nameof(AppRole.SysAdmin)},{nameof(AppRole.SuperAdmin)}")] 

<div class="d-flex flex-column w-100 flex-grow-1 px-4 pt-2" style="min-height: 0">
    <div class="text-start d-flex align-items-start flex-column flex-shrink-0">
        <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.West" OnClick="@(async () => await JS.InvokeVoidAsync("history.back"))">@Localizer[Langs.GoBack]</MudButton>
    </div>
    <div class="d-flex w-100 mt-6" style="gap: 100px; flex: 1 1 0; min-height: 0">
        <div class="d-flex flex-column justify-content-start align-items-start" style="min-width: 300px; flex: 0 0 auto; gap: 24px; min-height: 0; overflow-x: hidden">
            <MudText Typo="Typo.h5" Style="font-weight: 700;">@Localizer[Langs.SettingsCompany]</MudText>
            <MudList T="SectionsEnums.CompanySettingsSection" SelectionMode="SelectionMode.SingleSelection" SelectedValue="@_currentSection" SelectedValueChanged="OnSectionChanged">
                <MudListItem Value="SectionsEnums.CompanySettingsSection.Information" Text="@Localizer[Langs.GeneralInformation]" Icon="@Icons.Material.Outlined.Apartment" IconColor="@_currentSection.GetIconColor(SectionsEnums.CompanySettingsSection.Information)" Class="@_currentSection.GetNavClass(SectionsEnums.CompanySettingsSection.Information)" />
                <MudListItem Value="SectionsEnums.CompanySettingsSection.Logo" Text="@Localizer[Langs.Logo]" Icon="@Icons.Material.Outlined.PhotoSizeSelectActual" IconColor="@_currentSection.GetIconColor(SectionsEnums.CompanySettingsSection.Logo)" Class="@_currentSection.GetNavClass(SectionsEnums.CompanySettingsSection.Logo)" />
                <MudListItem Value="SectionsEnums.CompanySettingsSection.Contact" Text="@Localizer[Langs.ContactDetails]" Icon="@Icons.Material.Outlined.Call" IconColor="@_currentSection.GetIconColor(SectionsEnums.CompanySettingsSection.Contact)" Class="@_currentSection.GetNavClass(SectionsEnums.CompanySettingsSection.Contact)" />
                <MudListItem Value="SectionsEnums.CompanySettingsSection.Modules" Text="@Localizer[Langs.Modules]" Icon="@Icons.Material.Outlined.GridView" IconColor="@_currentSection.GetIconColor(SectionsEnums.CompanySettingsSection.Modules)" Class="@_currentSection.GetNavClass(SectionsEnums.CompanySettingsSection.Modules)" />
                <MudListItem Value="SectionsEnums.CompanySettingsSection.WorkTime" Text="@Localizer[Langs.WorkingHours]" Icon="@Icons.Material.Outlined.Timer" IconColor="@_currentSection.GetIconColor(SectionsEnums.CompanySettingsSection.WorkTime)" Class="@_currentSection.GetNavClass(SectionsEnums.CompanySettingsSection.WorkTime)" />
            </MudList>
        </div>
        <div class="flex-grow-1 d-flex flex-column align-items-start" style="min-height: 0; overflow-x: hidden; gap: 40px;">
            <CascadingValue Value="@_company" TValue="CompanyDTO" Name="Company">
                @switch(_currentSection)
                {
                    case SectionsEnums.CompanySettingsSection.Information:
                        <CompanyInformation/>
                        break;
                    case SectionsEnums.CompanySettingsSection.Logo:
                        <LogoSettings />
                        break;
                    case SectionsEnums.CompanySettingsSection.Contact:
                        <ContactSettings />
                        break;
                    case SectionsEnums.CompanySettingsSection.Modules:
                        <ModulesSettings />
                        break;
                    case SectionsEnums.CompanySettingsSection.WorkTime:
                        <WorkTimeSettings />
                        break;
                    default: break;
                }
            </CascadingValue>
        </div>
    </div>
</div>

@code {
    CompanyDTO? _company { get; set; }

    private SectionsEnums.CompanySettingsSection _currentSection = SectionsEnums.CompanySettingsSection.Information;

    private void OnSectionChanged(SectionsEnums.CompanySettingsSection section)
    {
        if (_currentSection == section)
            return;
        _currentSection = section;
        StateHasChanged();
    }


    protected override async Task OnInitializedAsync()
    {
        _company = await CompanyService.GetCurrentCompany();
        if (_company == null)
            throw new Exception("Company not found!");
    }
}
