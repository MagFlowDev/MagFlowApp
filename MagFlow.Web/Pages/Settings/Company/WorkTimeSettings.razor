@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Helpers.Converters.TimeConverters
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Shared.DTOs.CoreScope
@using MagFlow.Shared.Models
@using MagFlow.Web.Components.Buttons
@using MudBlazor
@using System.Globalization

@inject ICompanyService CompanyService
@inject ILocalCacheService LocalCacheService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<div class="d-flex flex-column align-items-start w-100" style="max-width: 590px; min-height: 0; gap: 24px; padding-right: 40px;">
    <div class="d-flex flex-column align-items-start w-100 align-self-stretch" style="gap: 40px;">
        <MudText Typo="Typo.h5">@Localizer[Langs.WorkingHours]</MudText>
        <div class="d-flex flex-column align-items-start align-self-stretch">
            @if (_company?.CompanySettings?.DefaultWorkingHourDTOs.Any() == true)
            {
                foreach (var workingHourDTO in _company.CompanySettings.DefaultWorkingHourDTOs)
                {
                    <div class="d-flex align-items-center align-self-stretch w-100" style="@($"padding: 10px 4px; border-bottom: 1px solid {Colors.Gray.Lighten2}")">
                        <MudCheckBox Color="Color.Primary" T="bool" Value="@(!workingHourDTO.IsClosed)" ValueChanged="((bool value) => ToggleClosedDay(workingHourDTO, value))" />
                        <MudText Typo="Typo.body1" Style="font-weight: 600">@workingHourDTO.DayOfWeek.GetDisplayName(Localizer)</MudText>
                        <div class=" d-flex flex-fill align-items-end justify-content-end ml-2" style="gap: 24px;">
                            @if (!workingHourDTO.IsClosed)
                            {
                                <div class="d-flex align-items-center" style="gap: 8px; max-height: 40px;">
                                    <MudText Typo="Typo.body1">@Localizer[Langs.FromTime]</MudText>
                                    <div class="d-flex align-items-center" style="max-width: 140px; margin: 8px 0px;">
                                        <MudTimePicker @bind-Time="workingHourDTO.OpenTime" Variant="Variant.Outlined" Adornment="Adornment.End" AmPm="@_amPmEnabled" MinuteSelectionStep="5" Editable="true" Converter="_timeConverter" />
                                    </div>
                                </div>
                                <div class="d-flex align-items-center" style="gap: 8px; max-height: 40px;">
                                    <MudText Typo="Typo.body1">@Localizer[Langs.ToTime]</MudText>
                                    <div class="d-flex align-items-center" style="max-width: 140px;">
                                        <MudTimePicker @bind-Time="workingHourDTO.CloseTime" Variant="Variant.Outlined" Adornment="Adornment.End" AmPm="@_amPmEnabled" MinuteSelectionStep="5" Editable="true" Converter="_timeConverter" />
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center align-self-stretch w-100 flex-shrink-0 justify-content-end" style="gap: 8px">
                                    <MudIcon Icon="@Icons.Material.Outlined.Timer" Color="Color.Secondary" Size="Size.Small"/>
                                    <MudText Color="Color.Secondary" Typo="Typo.body1">@Localizer[Langs.Closed]</MudText>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            }
        </div>
    </div>
    <div class="d-flex flex-column align-items-start w-100" style="padding-bottom: 40px">
        <LoadingButton Loading="_loadingUpdate" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="Update">@Localizer[Langs.Save]</LoadingButton>
    </div>
</div>

@code {
    [CascadingParameter(Name = "Company")]
    CompanyDTO? _company { get; set; }

    UserDTO? _user = null;
    bool _amPmEnabled;
    readonly TimeSpan12HConverter _timeConverter = new TimeSpan12HConverter();

    bool _loadingUpdate;
    bool _isBusy;

    protected override async Task OnParametersSetAsync()
    {
        if (_company != null && _company.CompanySettings == null)
            _company.CompanySettings = new CompanySettingsDTO();
        if (_company?.CompanySettings != null)
        {
            _company.CompanySettings.DefaultWorkingHourDTOs = await CompanyService.GetDefaultWorkingHours() ?? new List<DefaultWorkingHourDTO>();
            foreach (var dayOfWeek in (Enums.DayOfWeek[])Enum.GetValues<Enums.DayOfWeek>())
            {
                if (_company.CompanySettings.DefaultWorkingHourDTOs.Any(x => x.DayOfWeek == dayOfWeek))
                    continue;
                _company.CompanySettings.DefaultWorkingHourDTOs.Add(new DefaultWorkingHourDTO()
                {
                    DayOfWeek = dayOfWeek,
                    OpenTime = dayOfWeek != Enums.DayOfWeek.Saturday && dayOfWeek != Enums.DayOfWeek.Sunday ? new TimeSpan(8, 0, 0) : null,
                    CloseTime = dayOfWeek != Enums.DayOfWeek.Saturday && dayOfWeek != Enums.DayOfWeek.Sunday ? new TimeSpan(16, 0, 0) : null,
                    IsClosed = dayOfWeek == Enums.DayOfWeek.Saturday || dayOfWeek == Enums.DayOfWeek.Sunday,
                });
            }
            _company.CompanySettings.DefaultWorkingHourDTOs = _company.CompanySettings.DefaultWorkingHourDTOs.OrderBy(x => x.DayOfWeek).ToList();
        }

        if (_user == null)
            _user = await LocalCacheService.GetCurrentUser();
        _amPmEnabled = _user?.Settings.TimeFormat == Enums.TimeFormat.HH_MM_12H;
        StateHasChanged();
    }

    private async Task Update()
    {
        if (_isBusy || _company == null || !_company.Id.HasValue || _company.CompanySettings == null || !_company.CompanySettings.DefaultWorkingHourDTOs.Any())
            return;

        try
        {
            _isBusy = true;
            _loadingUpdate = true;

            var result = await CompanyService.UpdateDefaultWorkingHours(_company.CompanySettings.DefaultWorkingHourDTOs);
            if (result == Enums.Result.Success)
            {
                Snackbar.Add(Localizer[Langs.SettingsSaved], Severity.Success);
            }
            else
            {
                Snackbar.Add(Localizer[Langs.FailedUpdate], Severity.Error);
            }
        }
        finally
        {
            _isBusy = false;
            _loadingUpdate = false;
        }
    }

    private void ToggleClosedDay(DefaultWorkingHourDTO workingHourDTO, bool value)
    {
        workingHourDTO.IsClosed = !value;
        if(value)
        {
            if (!workingHourDTO.OpenTime.HasValue)
                workingHourDTO.OpenTime = new TimeSpan(8, 0, 0);
            if (!workingHourDTO.CloseTime.HasValue)
                workingHourDTO.CloseTime = new TimeSpan(16, 0, 0);
        }
        StateHasChanged();
    }
}
