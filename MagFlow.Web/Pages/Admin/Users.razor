@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CoreScope
@using MagFlow.Shared.Models.Enumerators
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Components.Pagination
@using MagFlow.BLL.Helpers.Localization.Display
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

@inject IUserService UserService
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = $"{nameof(AppRole.SysAdmin)},{nameof(AppRole.SuperAdmin)}")]

<div class="d-flex flex-column align-items-start w-100 h-100 overflow-hidden">
    <MagFlowDataGrid @ref="_usersDataGrid" T="UserDTO" ServerData="ServerReloadUsers" Filterable="false" OnRowClicked="OpenUserDetails">
        <ToolBarContent>
            <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Placeholder="Search" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Style="max-width: 400px"></MudTextField>
            <MudSpacer />
            <MudIconButton Color="Color.Primary" OnClick="_usersDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
        </ToolBarContent>
        <Columns>
            <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Name]" Sortable="true" Tag="@($"{nameof(UserDTO.LastName)}")" >
                <CellTemplate>
                    <MudLink Color="Color.Primary" Href="@($"/admin/user/{context.Item.Id}")">@string.Concat(context.Item.FirstName, " ", context.Item.LastName)</MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn T="UserDTO" TProperty="string" Title="@Localizer[Langs.Email]" Property="x => x.Email" Sortable="true"/>
            <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Companies]" Sortable="false">
                <CellTemplate>
                    <div class="d-flex align-items-center justify-content-start" style="gap: 4px">
                        @if(context.Item.Companies != null && context.Item.Companies.Count <= 3)
                        {
                            foreach(var company in context.Item.Companies)
                            {
                                <MudChip T="string" Class="m-0" Variant="Variant.Outlined">@company.DbName</MudChip>
                            }
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Role]" Sortable="false">
                <CellTemplate>
                    <MudText>@context.Item.Roles.FirstOrDefault()?.DisplayRole(Localizer)</MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="UserDTO" Title="@Localizer[Langs.LastLogin]" Sortable="false">
                <CellTemplate>
                    <MudText>@context.Item.LastLogin?.ToLocalTime().ToString()</MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Status]" Sortable="false">
                <CellTemplate>
                    <MudChip T="string" Class="m-0" Variant="Variant.Filled" Color="@(context.Item.IsActive ? Color.Success : Color.Error)">@(context.Item.IsActive ? Localizer[Langs.Active] : Localizer[Langs.Inactive])</MudChip>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MagFlowDataGrid>
</div>

@code {
    MudDataGrid<UserDTO> _usersDataGrid;
    string? _searchString = null;


    private async Task<GridData<UserDTO>> ServerReloadUsers(GridState<UserDTO> state, CancellationToken token)
    {
        var sortDefinition = state.SortDefinitions.FirstOrDefault();
        string? sortBy = sortDefinition?.SortBy;
        if(Guid.TryParse(sortBy, out _))
        {
            var column = _usersDataGrid.RenderedColumns.FirstOrDefault(c => c.PropertyName == sortBy);
            sortBy = column?.Tag?.ToString();
        }
        sortBy = sortBy ?? nameof(UserDTO.LastName);
        var response = await UserService.GetUsers(state.Page, state.PageSize, _searchString, sortBy, sortDefinition?.Descending == true);

        return new GridData<UserDTO>
        {
            Items = response.Elements,
            TotalItems = response.TotalCount,
        };
    }

    private Task OnSearch(string text)
    {
        _searchString = text;
        return _usersDataGrid.ReloadServerData();
    }



    private void OpenUserDetails(UserDTO user)
    {
        NavigationManager.NavigateTo($"/admin/user/{user.Id}");
    }
}
