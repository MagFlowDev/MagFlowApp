@using FluentValidation
@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Helpers.Localization.Display
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CoreScope
@using MagFlow.Shared.Models.Enumerators
@using MagFlow.Shared.Models.FormModels
@using MagFlow.Shared.Validators.Company
@using MagFlow.Shared.Validators.Resources
@using MagFlow.Web.Components.Buttons
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IUserService UserService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Validations> Validations
@inherits AuthComponentBase

<div class="d-flex flex-column align-items-start w-100" style="max-width: 590px; min-height: 0; gap: 16px; padding-right: 40px; margin-top: 24px;">
    <MudText Typo="Typo.subtitle1" Style="font-weight: 500">@Localizer[Langs.UserProfile]</MudText>
    @if (_user != null)
    {
        <EditForm EditContext="@_context" class="align-self-stretch d-flex flex-column align-items-start" style="gap: 16px; padding-bottom: 24px;">
            <div class="d-flex align-items-center align-self-stretch" style="padding: 8px 0; gap: 8px">
                <div class="d-flex align-items-center w-50" style="gap: 16px">
                    <MudIcon Icon="@Icons.Material.Outlined.DateRange" Size="Size.Small" Style="color: var(--mud-palette-text-secondary" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 400; color: var(--mud-palette-text-secondary">@string.Concat(Localizer[Langs.CreationDate], ": ", _user.CreatedAt.HasValue ? _user.CreatedAt.Value.ToLocalTime().ToShortDateString() : "---")</MudText>
                </div>
                <div class="d-flex align-items-start w-50" style="gap: 16px">
                    <MudIcon Icon="@Icons.Material.Outlined.Login" Size="Size.Small" Style="color: var(--mud-palette-text-secondary" />
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 400; color: var(--mud-palette-text-secondary)">@string.Concat(Localizer[Langs.LastLogin], ": ", _user.LastLogin.HasValue ? _user.LastLogin.Value.ToLocalTime().ToShortDateString() : "---")</MudText>
                </div>
            </div>
            <div class="d-flex flex-column align-items-start align-self-stretch" style="gap: 24px;">
                <div class="d-flex justify-content-between align-items-start align-self-stretch" style="gap: 8px">
                    <MudTextField Label="@Localizer[Langs.FirstName]" Variant="Variant.Outlined" T="string" @bind-Value="_user.FirstName" For="@(() => _model.GeneralInformation.FirstName)" Class="w-100 my-0"></MudTextField>
                    <MudTextField Label="@Localizer[Langs.LastName]" Variant="Variant.Outlined" T="string" @bind-Value="_user.LastName" For="@(() => _model.GeneralInformation.LastName)" Class="w-100 my-0"></MudTextField>
                </div>
                <MudTextField Label="@Localizer[Langs.Email]" Variant="Variant.Outlined" T="string" Text="@_user.Email" Class="w-100 my-0" Disabled></MudTextField>
                <MudTextField Label="@Localizer[Langs.Phone]" Variant="Variant.Outlined" T="string" @bind-Value="@_user.PhoneNumber" Class="w-100 my-0"></MudTextField>
            
                <MudSelect @bind-Value="_selectedRole" MultiSelection="false" T="AppRole" OuterClass="w-100" Variant="Variant.Outlined" Label="@Localizer[Langs.RoleSingle]" ReadOnly="@(!HasModulePermission("Users", PermissionFlags.Admin))">
                    @foreach (var appRole in Enumeration<Guid>.GetAll<AppRole>().Where(x => x.Id != AppRole.SuperAdmin.Id && x.Id != AppRole.SysAdmin.Id))
                    {
                        <MudSelectItem Value="appRole">@appRole.DisplayRole(Localizer)</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="CompanyDTO" @bind-SelectedValues="_selectedCompanies" MultiSelection="true" OuterClass="w-100" Variant="Variant.Outlined" Label="@Localizer[Langs.AssignedCompanies]">
                    @foreach (var company in _companies)
                    {
                        <MudSelectItem T="CompanyDTO" Value="company" Disabled>@company.Name</MudSelectItem>
                    }
                </MudSelect>
                
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.USERS_EDIT" Context="authorizedContext">
                    <Authorized>
                        <LoadingButton Loading="_loading" Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@Localizer[Langs.Save]</LoadingButton>
                    </Authorized>
                </AuthorizeView>
            </div>
        </EditForm>
    }
</div>

@code {
    [CascadingParameter(Name = "User")]
    UserDTO? _user { get; set; }

    private IValidator _validator;
    private UserFormModel _model;
    private EditContext _context;
    private ValidationMessageStore _messageStore;

    private AppRole? _selectedRole;
    private IReadOnlyCollection<CompanyDTO> _selectedCompanies = new List<CompanyDTO>();
    private List<CompanyDTO> _companies = new List<CompanyDTO>();

    private bool _isBusy;
    private bool _loading;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _model = new UserFormModel();
        _context = new EditContext(_model);
        _validator = new UserCreateFormValidator(Validations);
        _messageStore = new ValidationMessageStore(_context);
    }

    protected override void OnParametersSet()
    {
        if (_user != null && _selectedRole == null)
            _selectedRole = _user.Roles.FirstOrDefault();
        if (_user != null && _user.Companies?.Any() == true && !_companies.Any())
        {
            _companies = _user.Companies;
            _selectedCompanies = _user.Companies;
        }
    }

    private string GetCompanySelectionText(IReadOnlyList<string?> selectedValues)
    {
        return $"{string.Join(", ", selectedValues.Where(x => x != null).Select(x => x))}";

    }

    private async Task Submit()
    {
        if (_isBusy)
            return;

        if (!HasModulePermission("Users", PermissionFlags.Edit))
            return;

        try
        {
            _isBusy = true;
            _loading = true;

            FillModel();
            var isValid = await _messageStore.IsFormValid(_validator, _model);
            _context.NotifyValidationStateChanged();

            if (!isValid)
                return;

            //var result = await UserService.Update(_model, _selectedRole);
            // if (result == MagFlow.Shared.Models.Enums.Result.Success)
            // {
            //     Snackbar.Add(Localizer[Langs.ActionSucceed], MudBlazor.Severity.Success);
            // }
            // else
            // {
            //     Snackbar.Add(Localizer[Langs.ErrorOccured], MudBlazor.Severity.Error);
            // }
        }
        finally
        {
            _isBusy = false;
            _loading = false;
        }
    }

    private void FillModel()
    {
        if (_user == null)
            return;

        _model.GeneralInformation.FirstName = _user.FirstName;
        _model.GeneralInformation.LastName = _user.LastName;
        _model.GeneralInformation.Email = _user.Email;
        _model.GeneralInformation.PhoneNumber = _user.PhoneNumber;
    }

}