@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CoreScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.BLL.Helpers.Localization.Display
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IUserService UserService
@inject ICompanyService CompanyService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_usersDataGrid" T="UserDTO" ServerData="ServerReloadUsers" Filterable="false" OnRowClicked="OpenUserDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.UsersList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.USERS_ADD">
            <Authorized>
                <LoadingButton Loading="_loadingBlockMany" Color="Color.Error" Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.Lock" Class="mr-2" OnClick="BlockUsers">@Localizer[Langs.Block]</LoadingButton>
                <LoadingButton Loading="_loadingUnblockMany" Color="Color.Success" Variant="Variant.Outlined" StartIcon="@Icons.Material.Outlined.LockOpen" Class="mr-2" OnClick="UnblockUsers">@Localizer[Langs.Unblock]</LoadingButton>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteUsers">@Localizer[Langs.Delete]</LoadingButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddUserModal">@Localizer[Langs.AddUser]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_usersDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="UserDTO" />
        <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Status]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudChip T="string" Class="m-0" Variant="Variant.Filled" Color="@(context.Item.IsActive? Color.Success: Color.Error)">@(context.Item.IsActive? Localizer[Langs.Active] : Localizer[Langs.Inactive])</MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="UserDTO" TProperty="string" Title="@Localizer[Langs.FirstName]" Property="x => x.FirstName" Sortable="true" CellClass="text-nowrap" />
        <PropertyColumn T="UserDTO" TProperty="string" Title="@Localizer[Langs.LastName]" Property="x => x.LastName" Sortable="true" CellClass="text-nowrap" />
        <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Email]" Sortable="true" Tag="@($"{nameof(UserDTO.Email)}")" CellClass="text-nowrap">
            <CellTemplate>
                <MudLink Color="Color.Primary" OnClick="@(() => OpenUserDetails(context.Item))">@context.Item.Email</MudLink>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="UserDTO" Title="@Localizer[Langs.RoleSingle]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudText>@context.Item.Roles.FirstOrDefault()?.DisplayRole(Localizer)</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="UserDTO" Title="@Localizer[Langs.LastLogin]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudText>@context.Item.LastLogin?.ToLocalTime().ToString()</MudText>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="UserDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.USERS_READ">
                    <Authorized context="authorized_context1">
                        <MudTooltip Text="@Localizer[Langs.Open]" Delay="@Constants.Tooltip.DELAY">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.OpenInNew" OnClick="() => OpenUserDetails(context.Item)"/>
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.USERS_EDIT">
                    <Authorized context="authorized_context1">
                        @if (context.Item.IsActive)
                        {
                            <MudTooltip Text="@Localizer[Langs.Block]" Delay="@Constants.Tooltip.DELAY">
                                <LoadingIconButton Loading="LoadingBlock(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Lock" OnClick="() => BlockUser(context.Item)"/>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="@Localizer[Langs.Unblock]" Delay="@Constants.Tooltip.DELAY">
                                <LoadingIconButton Loading="LoadingBlock(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.LockOpen" OnClick="() => UnblockUser(context.Item)"/>
                            </MudTooltip>
                        }
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.USERS_DELETE">
                    <Authorized context="authorized_context1">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteUser(context.Item)"/>
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MagFlowDataGrid>
