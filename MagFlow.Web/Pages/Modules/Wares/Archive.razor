@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IItemService ItemService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_itemsDataGrid" T="ItemDTO" ServerData="ServerReloadItems" Filterable="false" OnRowClicked="OpenItemDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.Archive]</MudText>
        <MudSpacer />
        <MudIconButton Color="Color.Primary" OnClick="_itemsDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="ItemDTO" HeaderStyle="width: 1%" />
        <PropertyColumn T="ItemDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="item => (item.Product != null ? item.Product.Name : string.Empty)" />
        <PropertyColumn T="ItemDTO" TProperty="int" Title="@Localizer[Langs.Code]" Sortable="true" CellClass="text-nowrap" Property="item => item.Id" />
        <PropertyColumn T="ItemDTO" TProperty="string" Title="@Localizer[Langs.Type]" Sortable="false" CellClass="text-nowrap" Property="item => (item.Product != null && item.Product.Type != null ? item.Product.Type.Name : string.Empty)" />
        <PropertyColumn T="ItemDTO" TProperty="string" Title="@Localizer[Langs.Category]" Sortable="false" CellClass="text-nowrap" Property="item => (item.Product != null && item.Product.Category != null ? item.Product.Category.Name : string.Empty)" />
        <TemplateColumn T="ItemDTO" Title="@Localizer[Langs.StockQuantity]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                @($"{context.Item.Quantity:0.##} {context.Item.Unit?.Symbol}")
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="ItemDTO" TProperty="string" Title="@Localizer[Langs.Location]" Sortable="false" CellClass="text-nowrap" Property="item => item.Location" />
        <PropertyColumn T="ItemDTO" TProperty="string" Title="@Localizer[Langs.CreationDate]" Sortable="false" CellClass="text-nowrap" Property="item => (item.CreatedAt.HasValue ? item.CreatedAt.Value.ToLocalTime().ToShortDateString() : string.Empty)" />

    </Columns>
</MagFlowDataGrid>