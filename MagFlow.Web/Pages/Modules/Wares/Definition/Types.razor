@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_typesDataGrid" T="ProductTypeDTO" ServerData="ServerReloadProducts" Filterable="false" OnRowClicked="OpenTypeDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.ProductTypesList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
            <Authorized>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteTypes">@Localizer[Langs.Delete]</LoadingButton>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
            <Authorized>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddTypeModal">@Localizer[Langs.AddType]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_typesDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="ProductTypeDTO" HeaderStyle="width: 1%" />
        <PropertyColumn T="ProductTypeDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="type => type.Name" />
        <PropertyColumn T="ProductTypeDTO" TProperty="string" Title="@Localizer[Langs.Code]" Sortable="true" CellClass="text-nowrap" Property="type => type.Code" />
        <PropertyColumn T="ProductTypeDTO" TProperty="string" Title="@Localizer[Langs.Type]" Sortable="true" CellClass="text-nowrap" Property="type => (type.Category != null ? type.Category.Name : string.Empty)" />
        <TemplateColumn T="ProductTypeDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudTooltip Text="@Localizer[Langs.Edit]" Delay="@Constants.Tooltip.DELAY">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="async () => await OpenTypeDetails(context.Item)" />
                </MudTooltip>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteType(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MagFlowDataGrid>