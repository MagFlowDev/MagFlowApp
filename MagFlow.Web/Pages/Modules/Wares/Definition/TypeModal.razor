@using FluentValidation
@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.Models.Enumerators
@using MagFlow.Shared.Models.FormModels
@using MagFlow.Shared.Validators.Company
@using MagFlow.Shared.Validators.Resources
@using MagFlow.BLL.Helpers.Localization.Display
@using MagFlow.BLL.Mappers.Domain.CompanyScope
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Shared.Models
@using MagFlow.Web.Components.Buttons
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Validations> Validations

<MudDialog Style="max-width: 420px;">
    <DialogContent>
        <EditForm EditContext="@_context" class="w-100 h-100 align-self-stretch d-flex flex-column align-items-start" style="gap: 24px">
            <MudTextField Label="@Localizer[Langs.Code]" Class="my-0" Placeholder="@Localizer[Langs.CodeExample]" Variant="Variant.Outlined" T="string" @bind-Value="@_model.Code" For="@(() => _model.Code)"></MudTextField>
            <MudTextField Label="@Localizer[Langs.Name]" Class="my-0" Placeholder="@Localizer[Langs.TypeExample]" Variant="Variant.Outlined" T="string" @bind-Value="@_model.Name" For="@(() => _model.Name)"></MudTextField>
            <MudSwitch Label="@Localizer[Langs.BaseType]" Class="my-0" @bind-Value="@_model.IsBasic" For="@(() => _model.IsBasic)" Color="Color.Primary" />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Localizer[Langs.Cancel]</MudButton>
        <LoadingButton Loading="_loading" Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@Localizer[Langs.Save]</LoadingButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public ProductTypeDTO? Type { get; set; }

    private IValidator _validator;
    private ProductTypeFormModel _model;
    private EditContext _context;
    private ValidationMessageStore _messageStore;

    private bool _isBusy;
    private bool _loading;

    private async Task Submit()
    {
        if (_isBusy)
            return;

        try
        {
            _isBusy = true;
            _loading = true;

            var isValid = await _messageStore.IsFormValid(_validator, _model);
            _context.NotifyValidationStateChanged();

            if (!isValid)
                return;

            var result = Enums.Result.Error;
            if (Type != null && Type.Id != 0)
            {
                var dto = _model.ToDTO();
                dto.IsActive = Type.IsActive;
                dto.Id = Type.Id;
                result = await ProductService.UpdateType(dto);
            }
            else
            {
                result = await ProductService.AddType(_model);
            }
            if (result == MagFlow.Shared.Models.Enums.Result.Success)
            {
                Snackbar.Add(Localizer[Langs.ResourceCreated], MudBlazor.Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(Localizer[Langs.ErrorOccured], MudBlazor.Severity.Error);
                MudDialog.Close(DialogResult.Ok(false));
            }
        }
        finally
        {
            _isBusy = false;
            _loading = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _model = new ProductTypeFormModel();
        _context = new EditContext(_model);
        _validator = new ProductTypeValidator(Validations);
        _messageStore = new ValidationMessageStore(_context);

        this.MudDialog.SetOptionsAsync(new DialogOptions()
        {
            CloseButton = true,
            Position = DialogPosition.Center
        });
    }

    protected override void OnParametersSet()
    {
        if (Type != null && Type.Id != 0)
        {
            _model.Name = Type.Name;
            _model.Code = Type.Code;
            _model.IsBasic = Type.IsBasic;
        }
    }
}
