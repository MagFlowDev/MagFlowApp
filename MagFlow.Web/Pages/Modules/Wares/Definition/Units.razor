@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_unitsDataGrid" T="UnitDTO" ServerData="ServerReloadUnits" Filterable="false" OnRowClicked="OpenUnitDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.MeasurementUnitsList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
            <Authorized>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteUnits">@Localizer[Langs.Delete]</LoadingButton>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
            <Authorized>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddUnitModal">@Localizer[Langs.AddUnit]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_unitsDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <HierarchyColumn T="UnitDTO" HeaderStyle="width: 1%" ButtonDisabledFunc="@(x => !x.RelatedUnits.Any())" />
        <TemplateColumn T="UnitDTO" HeaderStyle="width: 1%">
            <HeaderTemplate>
                <MudCheckBox T="bool?" Value="@SelectAllStates()" ValueChanged="OnSelectAllChanged"/>
            </HeaderTemplate>
            <CellTemplate Context="ctx">
                <MudCheckBox T="bool" Value="@IsSelected(ctx.Item)" ValueChanged="@(v => ToggleSelection(ctx.Item, v))"/>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="UnitDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="unit => unit.Name"/>
        <PropertyColumn T="UnitDTO" TProperty="string" Title="@Localizer[Langs.Symbol]" Sortable="true" CellClass="text-nowrap" Property="unit => unit.Symbol"/>
        <TemplateColumn T="UnitDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudTooltip Text="@Localizer[Langs.Edit]" Delay="@Constants.Tooltip.DELAY">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="async () => await OpenUnitDetails(context.Item)"/>
                </MudTooltip>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteUnit(context.Item)"/>
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <ChildRowRenderer>
        @foreach (var child in context.Item.RelatedUnits)
        {
            <tr class="mud-table-row">
                <td class="mud-table-cell mud-table-child-content"></td>
                <td class="mud-table-cell mud-table-child-content" style="padding-right: 12px">
                    <MudCheckBox T="bool" Value="@IsSelected(child)" ValueChanged="@(v => ToggleSelection(child, v))" Class="align-items-end" ></MudCheckBox>
                </td>
                <td class="mud-table-cell mud-table-child-content pl-8">@child.Name</td>
                <td class="mud-table-cell mud-table-child-content pl-8">@child.Symbol</td>
                <td class="mud-table-cell mud-table-child-content pl-8">
                    <div class="d-flex align-items-center" style="gap: 4px">
                        <MudTooltip Text="@Localizer[Langs.Edit]" Delay="@Constants.Tooltip.DELAY">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="async () => await OpenUnitDetails(child)" />
                        </MudTooltip>
                        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                            <Authorized Context="authorizedContext">
                                <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                                    <LoadingIconButton Loading="LoadingDelete(child.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteUnit(child)" />
                                </MudTooltip>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </td>
            </tr>
        }
    </ChildRowRenderer>
</MagFlowDataGrid>