@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_categoriesDataGrid" T="ProductCategoryDTO" ServerData="ServerReloadProducts" Filterable="false" OnRowClicked="OpenCategoryDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.ProductCategoriesList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
            <Authorized>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteCategories">@Localizer[Langs.Delete]</LoadingButton>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
            <Authorized>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddCategoryModal">@Localizer[Langs.AddCategory]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_categoriesDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="ProductCategoryDTO" HeaderStyle="width: 1%" />
        <PropertyColumn T="ProductCategoryDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="category => category.Name" />
        <PropertyColumn T="ProductCategoryDTO" TProperty="string" Title="@Localizer[Langs.Code]" Sortable="true" CellClass="text-nowrap" Property="category => category.Code" />
        <TemplateColumn T="ProductCategoryDTO" Title="@Localizer[Langs.Basic]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <div class="d-flex align-items-center" style="gap: 8px">
                    @if (context.Item.IsBasic)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2">@Localizer[Langs.Yes]</MudText>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Cancel" Color="Color.Error" Size="Size.Small" />
                        <MudText Typo="Typo.body2">@Localizer[Langs.No]</MudText>
                    }
                </div>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="ProductCategoryDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudTooltip Text="@Localizer[Langs.Edit]" Delay="@Constants.Tooltip.DELAY">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="async () => await OpenCategoryDetails(context.Item)" />
                </MudTooltip>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteCategory(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MagFlowDataGrid>