@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_parametersDataGrid" T="ParameterDTO" ServerData="ServerReloadProducts" Filterable="false" OnRowClicked="OpenParameterDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.ProductParametersList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
            <Authorized>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteParameters">@Localizer[Langs.Delete]</LoadingButton>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
            <Authorized>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddParameterModal">@Localizer[Langs.AddParameter]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_parametersDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="ParameterDTO" HeaderStyle="width: 1%" />
        <PropertyColumn T="ParameterDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="parameter => parameter.Name" />
        <PropertyColumn T="ParameterDTO" TProperty="string" Title="@Localizer[Langs.Code]" Sortable="true" CellClass="text-nowrap" Property="parameter => parameter.Code" />
        <PropertyColumn T="ParameterDTO" TProperty="string" Title="@Localizer[Langs.ValueType]" Sortable="true" CellClass="text-nowrap" Property="parameter => parameter.ValueType.GetDisplayName(Localizer)" />
        <PropertyColumn T="ParameterDTO" TProperty="string" Title="@Localizer[Langs.Unit]" Sortable="true" CellClass="text-nowrap" Property="parameter => (parameter.Unit != null ? parameter.Unit.Symbol : string.Empty)" />
        <TemplateColumn T="ParameterDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <MudTooltip Text="@Localizer[Langs.Edit]" Delay="@Constants.Tooltip.DELAY">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="() => OpenParameterDetails(context.Item)" />
                </MudTooltip>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteParameter(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MagFlowDataGrid>