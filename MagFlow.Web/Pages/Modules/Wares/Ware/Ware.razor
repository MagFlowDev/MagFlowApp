@page "/item/{ItemId}"

@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Web.Components.Buttons
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using MagFlow.Web.Helpers
@using MagFlow.Shared.Models
@using MagFlow.Shared.Extensions.Enum
@using MagFlow.Shared.DTOs.CompanyScope

@inject IItemService ItemService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@layout TabsLayout
@inherits AuthComponentBase
@attribute [Authorize(Policy = MagFlow.Shared.Constants.Policies.Claims.WARES_READ)]

<div class="d-flex flex-column w-100 flex-grow-1 overflow-visible" style="min-height: 0;">
    <div class="d-flex align-items-center align-self-stretch justify-content-between w-100 overflow-visible" style="padding: 0; margin-bottom: 8px; position: relative;">
        <ReturnFab OnClick="@(() => NavigationManager.NavigateTo("/"))" />
        @* Header *@
        <div class="d-flex align-self-stretch align-items-center mud-height-full w-100" style="min-height: 64px; height: 64px; border-radius: 4px; background: var(--mud-palette-primary-text); ">
            <div class="d-flex align-self-stretch align-items-center justify-content-between w-100 px-4" style="margin-left: 48px;">
                <MudText Typo="Typo.h6" Style="font-weight: 500">@string.Concat(_item?.Product?.Name ?? string.Empty, " | ", _item?.Id.ToString() ?? string.Empty)</MudText>
                <div class="d-flex align-items-center align-self-stretch justify-content-end" style="gap: 16px;">
                    <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_EDIT" Context="authorizedContext">
                        <Authorized>
                            <LoadingButton Loading="_loadingDelete" Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Outlined.Delete" OnClick="DeleteItem">@Localizer[Langs.Delete]</LoadingButton>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex w-100" style="flex: 1 1 0; min-height: 0">
        <MudPaper Height="100%" Style="overflow:hidden; position:relative; background-color: transparent" Class="w-100" Elevation="0">
            <MudDrawerContainer Class="mud-height-full">
                <MudDrawer @bind-Open="@_isMenuOpened" Fixed="true" Elevation="0" Variant="@DrawerVariant.Mini" Breakpoint="Breakpoint.None">
                    <MudNavMenu>
                        <MudNavLink Icon="@(_isMenuOpened ? Icons.Material.Outlined.ChevronLeft : Icons.Material.Outlined.ChevronRight)" OnClick="@(() => { _isMenuOpened = !_isMenuOpened; })" Ripple="false" />
                        <MudTooltip Text="@Localizer[Langs.GeneralInformation]" Disabled="@_isMenuOpened" Delay="@Constants.Tooltip.DELAY" RootClass="w-100">
                            <MudNavLink Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Label" OnClick="@(() => OnSectionChanged(SectionsEnums.WareDetailsSection.GeneralInformation))" IconColor="@_currentSection.GetIconColor(SectionsEnums.WareDetailsSection.GeneralInformation)" Class="@_currentSection.GetNavClass(SectionsEnums.WareDetailsSection.GeneralInformation)">@Localizer[Langs.GeneralInformation]</MudNavLink>
                        </MudTooltip>
                        <MudTooltip Text="@Localizer[Langs.Components]" Disabled="@_isMenuOpened" Delay="@Constants.Tooltip.DELAY" RootClass="w-100">
                            <MudNavLink Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.ShapeLine" OnClick="@(() => OnSectionChanged(SectionsEnums.WareDetailsSection.Components))" IconColor="@_currentSection.GetIconColor(SectionsEnums.WareDetailsSection.Components)" Class="@_currentSection.GetNavClass(SectionsEnums.WareDetailsSection.Components)">@Localizer[Langs.Components]</MudNavLink>
                        </MudTooltip>
                        <MudTooltip Text="@Localizer[Langs.History]" Disabled="@_isMenuOpened" Delay="@Constants.Tooltip.DELAY" RootClass="w-100">
                            <MudNavLink Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.ReceiptLong" OnClick="@(() => OnSectionChanged(SectionsEnums.WareDetailsSection.History))" IconColor="@_currentSection.GetIconColor(SectionsEnums.WareDetailsSection.History)" Class="@_currentSection.GetNavClass(SectionsEnums.WareDetailsSection.History)">@Localizer[Langs.History]</MudNavLink>
                        </MudTooltip>
                    </MudNavMenu>
                </MudDrawer>
                <div class="d-flex flex-grow-1 justify-center align-center mud-height-full" style="padding-left: 8px; min-height: 0">
                    <CascadingValue Value="@_item" TValue="ItemDTO" Name="Item">
                        @switch (_currentSection)
                        {
                            case SectionsEnums.WareDetailsSection.GeneralInformation:
                                <div class="d-flex align-self-stretch w-100 mud-height-full overflow-auto justify-content-center" style="min-height: 0; background: var(--mud-palette-primary-text);">
                                    <WareGeneralInformation />
                                </div>
                                break;
                            case SectionsEnums.WareDetailsSection.Components:
                                <div class="d-flex align-self-stretch w-100 mud-height-full overflow-auto justify-content-center" style="min-height: 0; background: var(--mud-palette-primary-text);">
                                    <WareComponents />
                                </div>
                                break;
                            case SectionsEnums.WareDetailsSection.History:
                                <div class="d-flex align-self-stretch w-100 mud-height-full overflow-auto justify-content-center" style="min-height: 0; background: var(--mud-palette-primary-text);">
                                    <WareHistory />
                                </div>
                                break;
                            default: break;
                        }
                    </CascadingValue>
                </div>
            </MudDrawerContainer>
        </MudPaper>
    </div>
</div>

@code {
    [Parameter]
    public string ItemId { get; set; }
}
