@using FluentValidation
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Shared.Models.Enumerators
@using MagFlow.Shared.Models.FormModels
@using MagFlow.Shared.Validators.Resources
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<Validations> Validations
@inherits AuthComponentBase

<div class="d-flex flex-column align-items-start w-100" style="max-width: 800px; min-height: 0; gap: 16px; padding-right: 40px; margin-top: 24px;">
    <MudText Typo="Typo.subtitle1" Style="font-weight: 500">@Localizer[Langs.UnitConversions]</MudText>
    @if (_product != null)
    {
        <MagFlowDataGrid @ref="_conversionsDataGrid" T="UnitConversionDTO" Items="_product.UnitConversions" Filterable="false" MultiSelection="true" OnRowClicked="OpenConversionDetails" Class="align-self-stretch mud-table-overflow-hidden flex-grow-1 dg-fixed-pager striped-grid overflow-x-auto my-2 shadow-none">
            <ToolBarContent>
                <MudText Typo="Typo.h6">@Localizer[Langs.UnitConversions]</MudText>
                <MudSpacer />
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_EDIT">
                    <Authorized>
                        <LoadingButton Loading="_loading" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteSelectedConversions">@Localizer[Langs.Delete]</LoadingButton>
                        <LoadingButton Loading="_loading" Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="AddNewConversion">@Localizer[Langs.AddConversion]</LoadingButton>
                    </Authorized>
                </AuthorizeView>
            </ToolBarContent>
            <Columns>
                <SelectColumn T="UnitConversionDTO" HeaderStyle="width: 1%" />
                <PropertyColumn T="UnitConversionDTO" TProperty="string" Title="@Localizer[Langs.FromUnit]" CellClass="text-nowrap" Property="unit => (unit.FromUnit != null ? unit.FromUnit.Name : string.Empty)" />
                <PropertyColumn T="UnitConversionDTO" TProperty="string" Title="@Localizer[Langs.ToUnit]" CellClass="text-nowrap" Property="unit => (unit.ToUnit != null ? unit.ToUnit.Name : string.Empty)" />
                <PropertyColumn T="UnitConversionDTO" TProperty="decimal" Format="0.##" Title="@Localizer[Langs.Conversion]" CellClass="text-nowrap" Property="unit => unit.ConversionRate" />
                <PropertyColumn T="UnitConversionDTO" TProperty="string" Title="@Localizer[Langs.Description]" CellClass="text-nowrap" Property="unit => unit.Note" />
            </Columns>
        </MagFlowDataGrid>
    }
</div>

