@using FluentValidation
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Shared.Models.Enumerators
@using MagFlow.Shared.Models.FormModels
@using MagFlow.Shared.Validators.Company
@using MagFlow.Shared.Validators.Resources
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Pages.Modules.Wares.Definition
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<Validations> Validations
@inherits AuthComponentBase

<div class="d-flex flex-column align-items-start w-100" style="max-width: 800px; min-height: 0; gap: 16px; padding-right: 40px; margin-top: 24px;">
    @if (_product != null)
    {
        <EditForm EditContext="@_context" class="align-self-stretch d-flex flex-column align-items-start mud-height-full" style="gap: 16px; padding-bottom: 24px;">
            <div style="overflow-y: auto; flex-grow: 1; min-height: 0;" class="d-flex flex-column align-items-center pt-3">
                <div class="d-flex flex-column align-items-center w-100 mud-height-full" style="max-width: 800px;">
                    <MudDropContainer T="ParameterDTO" @ref="_parametersContainer" Items="@_parameters" ItemsSelector="@((item, dropzone) => item.DropZoneSelector == dropzone)" ItemDropped="ItemUpdated" CanDropClass="mud-border-success" Class="d-flex flex-wrap flex-grow-1 align-self-stretch" Style="min-height: 0;" Context="dzContext">
                        <ChildContent>
                            <div class="d-flex flex-grow-1 align-items-center mud-height-full align-self-stretch" Style="gap: 0">
                                <div class="d-flex flex-column align-items-start w-50 mud-height-full" style="gap: 16px; padding-top: 16px;">
                                    <div class="d-flex align-items-center align-self-stretch" style="gap: 12px">
                                        <MudText Typo="Typo.subtitle1" Class="text-nowrap" Style="font-weight: 500">@Localizer[Langs.ParameterList]</MudText>
                                        <MudTextField T="string" Value="_parameterSearchString" ValueChanged="@OnParameterSearchChanged" DebounceInterval="300" Variant="Variant.Text" Placeholder="@Localizer[Langs.Search]" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Search" />
                                        <LoadingButton Loading="_loadingAddParameter" onclick="@(async () => await AddParameter())" StartIcon="@Icons.Material.Outlined.Add" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="padding: 4px 10px; min-width: 80px;">@Localizer[Langs.Add]</LoadingButton>
                                    </div>
                                    <div class="d-flex align-items-start align-self-stretch mud-height-full" style="gap: 16px; padding: 0 0 16px 0; min-height: 0;">
                                        <MudDropZone T="ParameterDTO" Identifier="@MagFlow.Shared.Constants.Identificators.DropZoneID.AVAILABLE_SELECTOR" Style="min-height: 0; overflow-y: auto" Class="rounded-lg border-1 border-solid mud-border-lines-default flex-grow-1 align-self-stretch mud-height-full w-100">

                                        </MudDropZone>
                                    </div>
                                </div>
                                <div class="d-flex flex-grow-1 align-self-stretch mud-height-full align-items-center justify-content-center" style="max-width: 24px; min-width: 24px; width: 24px; padding: 16px 0">
                                    <div style="@($"width: 1px; background: {Colors.Gray.Lighten2}")" class="h-100"></div>
                                </div>
                                <div class="d-flex flex-column align-items-start w-50 mud-height-full" style="gap: 16px; padding-top: 16px;">
                                    <div class="d-flex flex-column align-items-center justify-content-center align-self-stretch mud-height-full" style="gap: 16px; padding: 0px 8px 16px 8px;">
                                        <div class="d-flex justify-content-between align-items-center align-self-stretch" style="gap: 10px">
                                            <MudText Typo="Typo.subtitle1" Class="text-nowrap" Style="font-weight: 500">@Localizer[Langs.SelectedParameters]</MudText>
                                            <MudTextField T="string" Value="_selectedParameterSearchString" ValueChanged="@OnSelectedParameterSearchChanged" DebounceInterval="300" Variant="Variant.Text" Placeholder="@Localizer[Langs.Search]" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Search" />
                                        </div>
                                        <div class="d-flex align-items-start align-self-stretch mud-height-full" style="gap: 16px; min-height: 0;">
                                            <MudDropZone T="ParameterDTO" Identifier="@MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR" Style="min-height: 0; overflow-y: auto" Class="rounded-lg border-2 border-dashed mud-border-lines-default flex-grow-1 align-self-stretch mud-height-full w-100">
                                                @if(!_parameters.Any(x => x.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR))
                                                {
                                                    <div class="d-flex flex-column align-self-stretch mud-height-full">
                                                        <div class="d-flex flex-column align-self-stretch mud-height-full align-items-center justify-content-center flex-shrink-0" style="gap: 24px; padding: 24px 0">
                                                            <div class="d-flex flex-column align-items-center align-self-stretch" style="gap: 24px">
                                                                <MudIcon Style="width: 80px; height: 80px;" Color="Color.Default" Icon="@Icons.Material.Outlined.MoveToInbox"/>
                                                                <MudText Typo="Typo.subtitle1" Style="font-weight: 500" Class="text-center">@Localizer[Langs.AddOrDragParameter]</MudText>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </MudDropZone>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </ChildContent>
                        <ItemRenderer>
                            @if (!dzContext.DropZoneHidden)
                            {
                                <div class="d-flex justify-content-between align-items-center align-self-stretch mx-3" style="@($"border-bottom: 1px solid {Colors.Gray.Lighten2}")">
                                    <MudText Typo="Typo.body1" Style="font-weight: 400">@dzContext.Name</MudText>
                                    @if (dzContext.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.AVAILABLE_SELECTOR)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.AddCircleOutline" OnClick="@(() => ChangeParemeterZone(dzContext, MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR))" />
                                    }
                                    else if (dzContext.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Outlined.RemoveCircleOutline" Color="Color.Error" OnClick="@(() => ChangeParemeterZone(dzContext, MagFlow.Shared.Constants.Identificators.DropZoneID.AVAILABLE_SELECTOR))"/>
                                    }
                                </div>
                            }
                        </ItemRenderer>
                    </MudDropContainer>
                     <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_EDIT" Context="authorizedContext">
                        <Authorized>
                            <LoadingButton Loading="Submitting" Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Class="align-self-start" Style="min-height: 37px;">@Localizer[Langs.Save]</LoadingButton>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </EditForm>
    }
</div>

@code {
    [CascadingParameter(Name = "Product")]
    ProductDTO? _product { get; set; }

    [Parameter]
    public EventCallback OnProductUpdated { get; set; }

    [Parameter]
    public bool Submitting { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private IValidator _validator;
    private ProductFormModel _model;
    private EditContext _context;
    private ValidationMessageStore _messageStore;

    private MudDropContainer<ParameterDTO> _parametersContainer;
    private string _parameterSearchString = "";
    private string _selectedParameterSearchString = "";
    private int _pageSize = 25;
    private bool _loadingAddParameter = false;
    private List<ParameterDTO> _parameters = new List<ParameterDTO>();

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _model = new ProductFormModel();
        _context = new EditContext(_model);
        _validator = new ProductFormValidator(Validations);
        _messageStore = new ValidationMessageStore(_context);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_product != null && _parameters?.Any() != true)
        {
            _parameters = new List<ParameterDTO>();
            _product.Parameters?.ForEach(parameter =>
            {
                parameter.DropZoneSelector = MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR;
                _parameters.Add(parameter);
            });
            await SearchForProductParameter("", CancellationToken.None);
            StateHasChanged();
            _parametersContainer?.Refresh();
        }
    }

    private async Task Submit()
    {
        if (IsBusy || _product == null)
            return;

        if (!HasModulePermission("Wares", PermissionFlags.Edit))
            return;

        try
        {
            IsBusy = true;
            Submitting = true;

            var parameters = _parameters.Where(x => x.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR).ToList();
            var parametersToRemove = _product.Parameters.Except(parameters).ToList();

            var result = await ProductService.UpdateProductParameters(_product, parameters, parametersToRemove);
            if (result == MagFlow.Shared.Models.Enums.Result.Success)
            {
                Snackbar.Add(Localizer[Langs.ChangesSaved], MudBlazor.Severity.Success);
                _product.Parameters = parameters;
            }
            else
            {
                Snackbar.Add(Localizer[Langs.ErrorOccured], MudBlazor.Severity.Error);
            }
        }
        finally
        {
            IsBusy = false;
            Submitting = false;
        }
    }

    private void ItemUpdated(MudItemDropInfo<ParameterDTO> dropItem)
    {
        if (dropItem.Item == null)
            return;

        dropItem.Item.DropZoneSelector = dropItem.DropzoneIdentifier;
    }

    private async Task OnParameterSearchChanged(string value)
    {
        _parameterSearchString = value;
        await SearchForProductParameter(_parameterSearchString, CancellationToken.None);
        StateHasChanged();
        _parametersContainer?.Refresh();
    }

    private async Task<IEnumerable<ParameterDTO>> SearchForProductParameter(string value, CancellationToken token)
    {
        _parameterSearchString = value;
        var response = await ProductService.GetParameters(0, _pageSize, _parameterSearchString);
        var alreadySelected = _parameters.Where(x => x.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR).ToList();
        var ids = alreadySelected.Select(x => x.Id);
        _parameters = response.Elements;
        _parameters = _parameters.Where(x => !ids.Contains(x.Id)).ToList();
        _parameters.AddRange(alreadySelected);
        return _parameters;
    }

    private async Task OnSelectedParameterSearchChanged(string value)
    {
        _selectedParameterSearchString = value;
        var selectedParameters = _parameters.Where(x => x.DropZoneSelector == MagFlow.Shared.Constants.Identificators.DropZoneID.SELECTED_SELECTOR).ToList();
        var searchedParameters = selectedParameters.Where(x => x.Name.IndexOf(_selectedParameterSearchString, StringComparison.OrdinalIgnoreCase) >= 0).ToList();
        var unsearchedParameters = selectedParameters.Except(searchedParameters).ToList();

        searchedParameters.ForEach(x => x.DropZoneHidden = false);
        unsearchedParameters.ForEach(x => x.DropZoneHidden = true);

        StateHasChanged();
        _parametersContainer?.Refresh();
    }

    private void ChangeParemeterZone(ParameterDTO parameter, string zone)
    {
        parameter.DropZoneSelector = zone;
        parameter.DropZoneHidden = false;
        StateHasChanged();
        _parametersContainer?.Refresh();
    }

    private async Task AddParameter()
    {
        if (Submitting || _loadingAddParameter || IsBusy)
            return;

        try
        {
            _loadingAddParameter = true;

            if (!HasModulePermission("Wares", PermissionFlags.Add))
                return;

            var dialog = await DialogService.ShowAsync<ParameterModal>(Localizer[Langs.AddParameter]);
            var confirmation = await dialog.Result;
            if (confirmation?.Data is bool result && result == true)
            {
                await SearchForProductParameter(_parameterSearchString, CancellationToken.None);
                StateHasChanged();
                _parametersContainer?.Refresh();
            }
        }
        finally
        {
            _loadingAddParameter = false;
        }
    }
}
