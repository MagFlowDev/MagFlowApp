@using MagFlow.BLL.Helpers
@using MagFlow.BLL.Services.Interfaces
@using MagFlow.Shared.DTOs.CompanyScope
@using MagFlow.Web.Components.Buttons
@using MagFlow.Web.Components.DataGrid
@using MagFlow.Web.Helpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IProductService ProductService
@inject IDialogService DialogService
@inject IAuthorizationService AuthorizationService
@inject ISnackbar Snackbar
@inject ILocalCacheService LocalCacheService
@inject NavigationManager NavigationManager
@inherits AuthComponentBase

<MagFlowDataGrid @ref="_productsDataGrid" T="ProductDTO" ServerData="ServerReloadProducts" Filterable="false" OnRowClicked="OpenProductDetails" MultiSelection="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">@Localizer[Langs.ProductsList]</MudText>
        <MudSpacer />
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
            <Authorized>
                <LoadingButton Loading="_loadingDeleteMany" Color="Color.Error" Variant="Variant.Filled" StartIcon="@Icons.Material.Outlined.Delete" Class="mr-2" OnClick="DeleteProducts">@Localizer[Langs.Delete]</LoadingButton>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
            <Authorized>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mr-2" OnClick="OpenAddProductModal">@Localizer[Langs.AddProduct]</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Color="Color.Primary" OnClick="_productsDataGrid.ReloadServerData" Class="mr-2" Icon="@Icons.Material.Outlined.Refresh" />
    </ToolBarContent>
    <Columns>
        <SelectColumn T="ProductDTO" HeaderStyle="width: 1%" />
        <PropertyColumn T="ProductDTO" TProperty="string" Title="@Localizer[Langs.Name]" Sortable="true" CellClass="text-nowrap" Property="product => product.Name" />
        <PropertyColumn T="ProductDTO" TProperty="string" Title="@Localizer[Langs.Code]" Sortable="true" CellClass="text-nowrap" Property="product => product.Code" />
        <PropertyColumn T="ProductDTO" TProperty="string" Title="@Localizer[Langs.Category]" Sortable="false" CellClass="text-nowrap" Property="@(product => (product.Category != null ? product.Category.Name : string.Empty))" />
        <PropertyColumn T="ProductDTO" TProperty="string" Title="@Localizer[Langs.Type]" Sortable="false" CellClass="text-nowrap" Property="@(product => (product.Type != null ? product.Type.Name : string.Empty))" />
        <PropertyColumn T="ProductDTO" TProperty="string" Title="@Localizer[Langs.UnitShort]" Sortable="false" CellClass="text-nowrap" Property="@(product => (product.Unit != null ? product.Unit.Name : string.Empty))" />
        <TemplateColumn T="ProductDTO" Title="@Localizer[Langs.PurchasePrice]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                @($"{context.Item.PurchasePrice:N2} {context.Item.Currency.GetDisplayName(Localizer)}")
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="ProductDTO" Title="@Localizer[Langs.SellingPrice]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                @($"{context.Item.SellingPrice:N2} {context.Item.Currency.GetDisplayName(Localizer)}")
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="ProductDTO" Title="@Localizer[Langs.TaxRate]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                @($"{context.Item.TaxRate?.ToDecimal():0.##}%")
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="ProductDTO" Title="@Localizer[Langs.Actions]" Sortable="false" CellClass="text-nowrap">
            <CellTemplate>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_READ">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Open]" Delay="@Constants.Tooltip.DELAY">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.OpenInNew" OnClick="() => OpenProductDetails(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_ADD">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.CreateCopy]" Delay="@Constants.Tooltip.DELAY">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.ContentCopy" OnClick="() => OpenAddProductModal(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Policy="@MagFlow.Shared.Constants.Policies.Claims.WARES_DELETE">
                    <Authorized Context="authorizedContext">
                        <MudTooltip Text="@Localizer[Langs.Delete]" Delay="@Constants.Tooltip.DELAY">
                            <LoadingIconButton Loading="LoadingDelete(context.Item.Id)" Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="() => DeleteProduct(context.Item)" />
                        </MudTooltip>
                    </Authorized>
                </AuthorizeView>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MagFlowDataGrid>